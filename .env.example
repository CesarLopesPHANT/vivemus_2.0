# =============================================
# Vivemus 2.0 - Variaveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositorio!

# --- Supabase (Frontend) ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# --- Google Gemini AI ---
GEMINI_API_KEY=sua-chave-gemini-aqui

# =============================================
# SECRETS (configurar APENAS no GitHub Actions)
# Nunca adicionar aqui - usar Repository Secrets
# =============================================
# SUPABASE_ACCESS_TOKEN - Token de acesso Supabase CLI
# SUPABASE_PROJECT_ID - ID do projeto Supabase
# SUPABASE_SERVICE_ROLE_KEY - Chave service_role (admin)
# DAV_API_KEY - Chave da API Doutor ao Vivo
# DAV_BASE_URL - https://api.v2.doutoraovivo.com.br
# DAV_TAG_ID - ID da tag Vivemus na DAV
