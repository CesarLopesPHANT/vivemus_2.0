{
  "name": "vivemus-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=@vivemus/web",
    "dev:mobile": "npm run dev --workspace=@vivemus/mobile-patient",

    "build": "npm run build --workspace=@vivemus/web",
    "build:web": "npm run build --workspace=@vivemus/web",
    "build:mobile": "npm run build --workspace=@vivemus/mobile-patient",
    "build:all": "npm run build:web && npm run build:mobile",

    "preview": "npm run preview --workspace=@vivemus/web",

    "start": "serve -s apps/web/dist -l $PORT"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@supabase/supabase-js": "^2.78.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "serve": "^14.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "supabase": "^2.76.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
