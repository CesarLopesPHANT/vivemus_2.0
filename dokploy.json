{
  "app": "vivemus-web",
  "buildCommand": "npm ci && npm run build:web",
  "startCommand": "npm run start",
  "port": 3000,
  "env": {
    "NODE_ENV": "production",
    "GEMINI_API_KEY": "${GEMINI_API_KEY}",
    "DAV_API_KEY": "${DAV_API_KEY}",
    "VITE_SUPABASE_URL": "${VITE_SUPABASE_URL}",
    "VITE_SUPABASE_ANON_KEY": "${VITE_SUPABASE_ANON_KEY}"
  },
  "healthCheck": {
    "path": "/",
    "port": 3000,
    "interval": 30,
    "timeout": 10,
    "retries": 3
  }
}
