<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Camera e microfone para teleconsulta -->
	<key>NSCameraUsageDescription</key>
	<string>O Vivemus precisa acessar sua camera para a teleconsulta com o medico.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>O Vivemus precisa acessar seu microfone para a teleconsulta com o medico.</string>

	<!-- App Transport Security - somente HTTPS para dominios de telemedicina -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>api.v2.doutoraovivo.com.br</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
			<key>doutoraovivo.com.br</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
